APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

CHATBOT_ALLOW_OTP_FALLBACK=false

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_URL=https://graph.facebook.com/v21.0
WHATSAPP_VALIDATE_SIGNATURE=false
WHATSAPP_QUEUE_OUTBOUND=true
WHATSAPP_OUTBOUND_QUEUE=whatsapp
WHATSAPP_DEFAULT_COUNTRY_CODE=224
WHATSAPP_SESSION_TTL_MINUTES=30
WHATSAPP_TRANSACTION_LIMIT=5000000
WHATSAPP_OTP_THRESHOLD=100000
WHATSAPP_DEFAULT_CURRENCY=GNF

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edgpay_backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Remboursements (créances) - notification admin
# Mode d'envoi: queue (par défaut, nécessite un worker) ou sync (immédiat, pratique en local)
CREDIT_REIMBURSEMENT_MAIL_MODE=queue
# Emails admin destinataires (séparés par virgules). Si vide, fallback sur admin assigné puis admins credits.manage.
CREDIT_REIMBURSEMENT_NOTIFY_EMAILS=

# Reçus (créances) - email au client lors de la validation admin
# Mode d'envoi: queue (prod, nécessite un worker) ou sync (immédiat, pratique en local)
CREDIT_RECEIPT_MAIL_MODE=

# Rejet (créances) - email au client lors du rejet admin (transaction ou soumission)
# Mode d'envoi: queue (prod, nécessite un worker) ou sync (immédiat, pratique en local)
CREDIT_REJECTION_MAIL_MODE=


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
