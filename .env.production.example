APP_NAME=EdgPay
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edgpay
DB_USERNAME=edgpay_user
DB_PASSWORD=

CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file

CHATBOT_ALLOW_OTP_FALLBACK=false

WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token
WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_GRAPH_URL=https://graph.facebook.com/v21.0
WHATSAPP_VALIDATE_SIGNATURE=true
WHATSAPP_QUEUE_OUTBOUND=true
WHATSAPP_OUTBOUND_QUEUE=whatsapp
WHATSAPP_DEFAULT_COUNTRY_CODE=224
WHATSAPP_SESSION_TTL_MINUTES=30
WHATSAPP_TRANSACTION_LIMIT=5000000
WHATSAPP_OTP_THRESHOLD=100000
WHATSAPP_DEFAULT_CURRENCY=GNF